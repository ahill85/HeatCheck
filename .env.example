# Optional: after the repo is on GitHub, point the live site at the data files
# so GitHub Actions can refresh trends without re-uploading the whole site.
#
# Example (replace USER/REPO):
# VITE_DATA_URL=https://raw.githubusercontent.com/USER/REPO/main/public/data
#
# Then rebuild once: npm run build
# Upload dist/ to astarmedia.net/heatcheck/
VITE_DATA_URL=
